{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "large"
      }
    },
    "preview": {
      "ios": {
        "resourceClass": "large"
      },
      "android": {
        "resourceClass": "large"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.yourdomain.com"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://chuio.io"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "environment": "development"
    }
  },
  "submit": {
    "production": {}
  }
}
