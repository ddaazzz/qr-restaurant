{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "large"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large"
      }
    },
    "preview": {
      "channel": "preview",
      "ios": {
        "resourceClass": "large",
        "bundleIdentifier": "com.qrrestaurant.app.dev"
      },
      "android": {
        "buildType": "apk",
        "resourceClass": "large",
        "applicationId": "com.qrrestaurant.app.dev"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dev.chuio.io",
        "EXPO_PUBLIC_APP_ENV": "dev"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "resourceClass": "large"
      },
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "large"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://chuio.io",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "environment": "development"
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "environment": "development"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "production"
      }
    }
  }
}
