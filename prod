#!/bin/bash
# ─────────────────────────────────────────────────────────────
#  prod — password-gated production operations
#  Usage:  ./prod <command>
#  Commands:
#    migrate       run pending migrations against prod DB
#    deploy        merge dev → main via GitHub API (triggers Render deploy)
#    db-check      show prod DB restaurant/terminal status
#    set-password  store the prod password in ~/.prod_pass (run once)
# ─────────────────────────────────────────────────────────────

PASS_FILE="$HOME/.prod_pass"
PROD_DB="postgresql://chuio_demo_user:lA7yJYtXe8gUFPg5j60Sc77nx9XeXnjP@dpg-d5neo34mrvns73fmt0sg-a.singapore-postgres.render.com/chuio_demo?sslmode=require"
GITHUB_REPO="ddaazzz/qr-restaurant"
BACKEND_DIR="$(cd "$(dirname "$0")/qr-restaurant-ai/backend" 2>/dev/null || cd "$(dirname "$0")/backend" 2>/dev/null && pwd)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

RED='\033[0;31m'
YEL='\033[1;33m'
GRN='\033[0;32m'
NC='\033[0m'

# ── set-password (no auth needed) ──────────────────────────────
if [[ "$1" == "set-password" ]]; then
  read -s -p "Enter new prod password: " pw1; echo
  read -s -p "Confirm password: " pw2; echo
  if [[ "$pw1" != "$pw2" ]]; then echo -e "${RED}Passwords do not match.${NC}"; exit 1; fi
  echo "$pw1" > "$PASS_FILE"
  chmod 600 "$PASS_FILE"
  echo -e "${GRN}✅ Password saved to $PASS_FILE${NC}"
  exit 0
fi

# ── check password file exists ─────────────────────────────────
if [[ ! -f "$PASS_FILE" ]]; then
  echo -e "${RED}No prod password set. Run:  ./prod set-password${NC}"
  exit 1
fi

STORED_PASS=$(cat "$PASS_FILE")

# ── authenticate ───────────────────────────────────────────────
echo -e "${YEL}⚠️  PRODUCTION OPERATION: $1${NC}"
read -s -p "Enter prod password: " input_pass; echo
if [[ "$input_pass" != "$STORED_PASS" ]]; then
  echo -e "${RED}❌ Wrong password. Aborted.${NC}"
  exit 1
fi
echo -e "${GRN}✅ Authenticated${NC}"

# ── commands ───────────────────────────────────────────────────
case "$1" in

  migrate)
    echo -e "${YEL}Running migrations against PRODUCTION DB...${NC}"
    cd "$SCRIPT_DIR/qr-restaurant-ai/backend" 2>/dev/null || cd "$SCRIPT_DIR/backend"
    DATABASE_URL="$PROD_DB" npx ts-node scripts/run-all-migrations.ts
    echo -e "${GRN}✅ Migrations complete.${NC}"
    ;;

  deploy)
    if [[ -z "$GITHUB_TOKEN" ]]; then
      read -p "GitHub token (or set \$GITHUB_TOKEN): " GITHUB_TOKEN
    fi
    echo -e "${YEL}Merging dev → main on GitHub (triggers Render deploy)...${NC}"
    RESULT=$(curl -s -X POST \
      -H "Authorization: token $GITHUB_TOKEN" \
      -H "Accept: application/vnd.github.v3+json" \
      "https://api.github.com/repos/$GITHUB_REPO/merges" \
      -d '{"base":"main","head":"dev","commit_message":"chore: merge dev into main"}' \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('message','') or 'merged: '+d.get('sha','')[:8])" 2>/dev/null)
    echo -e "${GRN}✅ $RESULT${NC}"
    ;;

  db-check)
    echo -e "${YEL}Prod DB status...${NC}"
    cd "$SCRIPT_DIR/qr-restaurant-ai/backend" 2>/dev/null || cd "$SCRIPT_DIR/backend"
    node -e "
const { Pool } = require('pg');
const p = new Pool({ connectionString: '$PROD_DB' });
Promise.all([
  p.query('SELECT id, name, active_payment_vendor FROM restaurants ORDER BY id'),
  p.query('SELECT id, restaurant_id, vendor_name, terminal_ip, terminal_port, is_active FROM payment_terminals ORDER BY restaurant_id'),
  p.query('SELECT name FROM migrations ORDER BY id DESC LIMIT 3'),
]).then(([r,t,m]) => {
  console.log('Restaurants:');
  r.rows.forEach(x => console.log(' ',x.id, x.name, '| vendor:', x.active_payment_vendor));
  console.log('Terminals:');
  t.rows.forEach(x => console.log(' ',x.id,'rest:',x.restaurant_id, x.vendor_name, (x.terminal_ip||'-')+':'+(x.terminal_port||'-'), 'active:',x.is_active));
  console.log('Last 3 migrations:', m.rows.map(x=>x.name).join(', '));
  p.end();
}).catch(e => { console.error(e.message); process.exit(1); });
"
    ;;

  *)
    echo "Usage: ./prod <command>"
    echo "Commands: migrate | deploy | db-check | set-password"
    exit 1
    ;;
esac
